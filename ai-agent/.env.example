# Copy this file to .env (same folder) and fill in the service-role key.
# .env is gitignored — never commit the real key.

# The whiteboard project's URL (already known):
SUPABASE_URL=https://bjyhhubhdtjjyyawppfs.supabase.co

# Supabase dashboard -> Project Settings -> API -> "service_role" secret key
# (same key the mcp-server uses). The agent is a backend service, so it uses
# service-role to read snapshots and join the Realtime channel.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Which board the agent watches. Defaults to "Test Board" if unset — open
# that same board in the browser to see the agent's presence.
AGENT_BOARD_ID=14d40240-541a-483c-b841-aef960305eaf

# console.anthropic.com -> API Keys. Used for the reasoning-loop tool-use
# calls (step 10) — never fetched or hardcoded, put your own key here.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
